#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;
const ll MLOG = 20;

int up[200005][MLOG], depth[200005];
vector<vector<int>> adj(200005, vector<int>());
vector<int> ans;

void binary_lift(int node, int par){
    up[node][0] = par;
    for(int i = 1; i < MLOG; i++){
        if(up[up[node][i-1]][i-1] != 0){
            up[node][i] = up[up[node][i-1]][i-1];
        }
    }
    
    for(int next:adj[node]){
        if (next == par)continue;
        binary_lift(next, node);
    }
}

void solve() {
    int n, q; cin >> n >> q;
    for(int i = 2; i <= n; i++){
        int x; cin >> x;
        adj[x].pb(i);
    }
    
    binary_lift(1, 0);
    
    for(int i = 0; i < q; i++){
        int node, jump; cin >> node >> jump;
        
        for(int k = 0; k < MLOG; k++){
            if(1<<k & jump){
                node = up[node][k];
            }
        }
        
        if(node == 0)node = -1;
        ans.pb(node);
    }
    
    for(auto x:ans)cout <<  x << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
    
    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
