#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;

vector<vector<int>> adj(200005, vector<int>());
vector<int> dp(200005, 0);
int ans = 0;

void dfs(int node, int par){
    vector<int> x;
    for(int next: adj[node]){
        if (next == par)continue;
        dfs(next, node);
        dp[node] = max(dp[node], dp[next]);
        x.pb(dp[next]);
    }
    
    sort(x.begin(), x.end(), greater<int>());
    if(x.size() >= 2){
        ans = max(ans, 1 + x[0] + x[1]);
    }else if(x.size() > 0){
        ans = max(ans, 1 + x[0]);
    }else{
        ans = max(ans, 1);
    }
    
    dp[node]++;
}

void solve() {
    int n; cin >> n;
    for(int i = 0; i < n-1; i++){
        int x; int y; cin >> x >> y;
        adj[x].pb(y);
        adj[y].pb(x);
    }
    
    dfs(1, -1);
    
    cout << ans -1 << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
