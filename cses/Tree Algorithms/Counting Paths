#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;
const ll MLOG = 20;

int up[200005][MLOG], depth[200005];
vector<vector<int>> adj(200005, vector<int>());
vector<int> ans(200005, 0), sweep(200005, 0);

void binary_lift(int node, int par){
    up[node][0] = par;
    for(int i = 1; i < MLOG; i++){
        if(up[up[node][i-1]][i-1] != 0){
            up[node][i] = up[up[node][i-1]][i-1];
        }
    }
    
    for(int next:adj[node]){
        if (next == par)continue;
        binary_lift(next, node);
    }
}

void dfs(int node, int par, int d){
    depth[node] = d;
    for(auto next:adj[node]){
        if (par == next) continue;
        dfs(next, node, d+1);
    }
}

pair<int,int> calc(int a, int b){
    if (depth[a] < depth[b])swap(a,b);
    
    int dist = depth[a] - depth[b];
    for(int k = MLOG-1; k >= 0; k--){
        if(1<<k & dist){
            a = up[a][k];
        }
    }
    
    if (a==b)return {a,b};
    
    for(int k = MLOG-1; k >= 0; k--){
        if(up[a][k] != up[b][k]){
            a = up[a][k];
            b = up[b][k];
        }
    }

    return {a,b};
}

int f(int node, int par){
    
    int cur = 0;
    for(int next: adj[node]){
        if(next == par) continue;
        cur += f(next, node);
    }
    
    cur += sweep[node];
    ans[node] += max(0, cur);
    
    return cur;
}

void solve() {
    int n, q; cin >> n >> q;
    for(int i = 0; i < n-1; i++){
        int x, y; cin >> x >> y;
        adj[x].pb(y);
        adj[y].pb(x);
    }
    
    binary_lift(1, 0);
    dfs(1, 0 , 0);
    
    for(int i = 0; i < q; i++){
        int x, y; cin >> x >> y;
        pair<int,int> minus = calc(x,y);
        
        if(minus.first == minus.second){
            if(x==minus.first){
                sweep[y]++;
                sweep[x]--;
                ans[x]++;
            }else{
                sweep[x]++;
                sweep[y]--;
                ans[y]++;
            }
        }else{
            sweep[x]++;
            sweep[y]++;
            ans[up[minus.first][0]]++;
            ans[minus.first]++;
            ans[minus.second]++;
            sweep[minus.first]--;
            sweep[minus.second]--;
        }
    }
    
    f(1, 0);
    
    for(int i = 1; i <= n; i++)cout << ans[i] << ' ';
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
    
    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
