#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;

int up[200005][20];
vector<int> ans;

void solve() {
    int n, q; cin >> n >> q;
    for(int i = 2; i <= n; i++){
    	cin >> up[i][0];
    }
    
    for(int k = 1; k < 20; k++){
    	for(int i = 1; i <= n; i++){
    	    up[i][k] = up[up[i][k-1]][k-1];
		}
	}
    
    for(int i = 0; i < q; i++){
        int node, jump; cin >> node >> jump;
        
        int x = node;
        for(int k = 0; k < 20; k++){
    		if(1<<k & jump){
    			x = up[x][k];
			}
		}
		
		if(x == 0)x = -1;
		
		ans.pb(x);
    }
    
    for(auto x:ans)cout <<  x << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
