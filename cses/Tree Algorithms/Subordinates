#include <bits/stdc++.h>
using namespace std;
 
#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;
 
vector<int> ans(200005, 0);
vector<vector<int>> adj(200005, vector<int>());
 
int dfs(int node){
    for(int next: adj[node]){
        ans[node] += dfs(next);
    }
 
    return ans[node] + 1;
}
 
void solve() {
    int n;
    
    cin >> n;
    for(int i = 2; i <= n; i++){
        int x; cin >> x;
        adj[x].pb(i);
    }
    
    dfs(1);
    
    for(int i = 1; i <= n; i++){
        cout << ans[i] << ' ';
    }
}
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
