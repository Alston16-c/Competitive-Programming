#include <bits/stdc++.h>
using namespace std;
 
#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
 
void solve() {
    ll n, arr[200005], ans; cin >> n;
    for(int i = 0; i < n; i++)cin >> arr[i];
    
    ans = arr[0];
    for(int i = 0; i < n; i++)ans = max(ans, arr[i]);
    if(ans < 0){
        cout << ans << endl;
        return;
    }
    
    ll cur = 0;
    for(int i = 0; i < n; i++){
        cur += arr[i];
        if(cur < 0)cur = 0;
        
        if(cur > ans)ans = cur;
    }
    
    cout << ans << endl;
}
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int t = 1;
    //cin >> t;
    while (t--) solve();
}
