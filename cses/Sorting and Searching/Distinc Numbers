#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;

void solve() {
    int n, arr[200005], ans = 0; cin >> n;
    map<int,int> cnt;
    for(int i = 0; i < n; i++) cin >> arr[i];
    
    for(int i = 0; i < n; i++){
        if(cnt.find(arr[i]) == cnt.end()){
            cnt[arr[i]] = 1;
            ans++;
        }
    }
    
    cout << ans << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    int t = 1;
    //cin >> t;
    while (t--) solve();
}
