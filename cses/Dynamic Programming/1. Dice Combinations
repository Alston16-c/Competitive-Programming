#include <bits/stdc++.h>
using namespace std;
 
#define pb push_back
#define ll long long
 
void solve() {
    ll n, dp[1000100]; cin >> n;
    for(int i = 0; i < 1000100; i++)dp[i] = 0;
    
    dp[0] = 1;
    for(int i  = 0; i <= n; i++){
        for(int j = 1; j <=6; j++){
            dp[i+j] += dp[i];
            dp[i+j] %= 1000000007;
        }
    }
    
    cout << dp[n] % 1000000007<< endl;
}
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int t = 1;
    //cin >> t;
    while (t--) solve();
}
