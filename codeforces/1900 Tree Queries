#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;
const ll MLOG = 20;

int up[200005][MLOG], depth[200005];
vector<vector<int>> adj(200005, vector<int>());
vector<string> ans;

void binary_lift(int node, int par){
    up[node][0] = par;
    for(int i = 1; i < MLOG; i++){
        if(up[up[node][i-1]][i-1] != 0){
            up[node][i] = up[up[node][i-1]][i-1];
        }
    }
    
    for(int next:adj[node]){
        if (next == par)continue;
        binary_lift(next, node);
    }
}

void dfs(int node, int par, int d){
    depth[node] = d;
    for(auto next:adj[node]){
        if (par == next) continue;
        dfs(next, node, d+1);
    }
}

int lca(int deepest, int check){
    int dist = depth[deepest] - depth[check], res = 0;
    for(int k = MLOG-1; k >= 0; k--){
        if(1<<k & dist){
            deepest = up[deepest][k];
        }
    }
    
    if (deepest==check)return 0;
    
    for(int k = MLOG-1; k >= 0; k--){
        if(up[deepest][k] != up[check][k]){
            deepest = up[deepest][k];
            check = up[check][k];
            res += (1<<k);
        }
    }

    return res + 1;
}

int find_ans(vector<pair<int,int>>& query_list){
    int deepest = query_list[query_list.size()-1].second;
    for(int i = 0; i < query_list.size()-1; i++){
        if (lca(deepest, query_list[i].second) > 1)return false;
    }
    return true;
}

void solve() {
    int n, q; cin >> n >> q;
    for(int i = 0; i < n-1; i++){
        int x, y; cin >> x >> y;
        adj[x].pb(y);
        adj[y].pb(x);
    }
    
    binary_lift(1, 0);
    dfs(1, 0 , 0);
    
    for(int i = 0; i < q; i++){
        int num_q; cin >> num_q;
        vector<pair<int,int>> query_list;
        
        for(int j = 0; j < num_q; j++){
            int x; cin >> x;
            query_list.pb({depth[x], x});
        }
        
        sort(query_list.begin(), query_list.end());
        if(find_ans(query_list)){
            ans.pb("YES");
        }else{
            ans.pb("NO");
        }
    }
    
    for(auto x:ans)cout <<  x << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
    
    int t = 1;
    //cin >> t;
    while (t--) solve();
    return 0;
}
