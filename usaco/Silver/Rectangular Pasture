#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;
const ll MOD = 1e9 + 7;

void solve() {
    ll n, ans = 0; cin >> n;
    int higher[2505][2505], lower[2505][2505];
    pair<ll,ll> c[2505];
    for(int i = 0; i < n; i++)cin >> c[i].first >> c[i].second;
    
    sort(c, c+n);
    
    for(int i = 0; i < n; i++){
        lower[i][0] = 0;
        if(c[0].second < c[i].second)lower[i][0] = 1;
        for(int j = 1; j < n; j++){
            lower[i][j] = lower[i][j-1];
            if (c[i].second > c[j].second)lower[i][j] += 1;
        }
    }
    
    for(int i = 0; i < n; i++){
        higher[i][0] = 0;
        if(c[0].second > c[i].second)higher[i][0] = 1;
        for(int j = 1; j < n; j++){
            higher[i][j] = higher[i][j-1];
            if (c[i].second < c[j].second)higher[i][j] += 1;
        }
    }
    
    for(int i = 0; i < n; i++){
        for(int j = i+1; j < n; j++){
            ans++;
            ll low, high;
            if (c[i].second < c[j].second){
                low = lower[i][j] - lower[i][i];
                high = higher[j][j] - higher[j][i];
            }else{
                high = higher[i][j] - higher[i][i];
                low = lower[j][j] - lower[j][i];
            }
            ans += high + low + high*low;
        }
    }
    
   
    
    cout << ans + n + 1 << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    int t = 1;
    //cin >> t;
    while (t--) solve();
}
