//sweep line

#include <bits/stdc++.h>
using namespace std;

#define pb push_back
#define ll long long  
const ll INF = 1e18L + 5;

void solve() {
    int n, k, q[1000006], arr[1000006]; cin >> n >> k;
    memset(q, 0, sizeof(q));
    memset(arr, 0, sizeof(arr));
    for(int i = 0; i < k; i++){
        int l, r; cin >> l >> r;
        q[l] += 1;
        q[r+1] -= 1;
    }
    
    
    int cur = 0;
    for(int i = 1; i <= n; i++){
        cur += q[i];
        arr[i] += cur;
    }
    
    sort(arr+1, arr+n+1);
    cout << arr[n/2 + 1] << endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    int t = 1;
    //cin >> t;
    while (t--) solve();
}
